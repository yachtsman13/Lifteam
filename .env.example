# LiftTeam Environment Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database (PostgreSQL for Docker, SQLite for standalone)
DATABASE_URL=

# PostgreSQL settings (used by docker-compose)
POSTGRES_DB=lifteam
POSTGRES_USER=lifteam
POSTGRES_PASSWORD=lifteam_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_PASSWORD=lifteam_secret

# Redis
REDIS_URL=redis://redis:6379/0

# Email
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=LiftTeam <noreply@example.com>

# Language/Timezone
LANGUAGE_CODE=ru-ru
TIME_ZONE=Europe/Moscow